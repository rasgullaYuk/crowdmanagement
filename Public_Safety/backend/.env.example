# Gemini configuration (required for Gemini-powered analysis)
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY

# Optional: comma-separated key pool for round-robin usage
# GEMINI_API_KEYS=key1,key2,key3

# Twilio (optional: SMS alerting)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+15005550006

# Supabase (optional: persistence)
SUPABASE_URL=
SUPABASE_KEY=
